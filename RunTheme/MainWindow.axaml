<Window xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="820" d:DesignHeight="520" x:Class="RunTheme.MainWindow" Title="Theme Editor - Docklys" Width="820" Height="520" MinWidth="540" MinHeight="360" WindowStartupLocation="CenterScreen" RequestedThemeVariant="Dark" Background="#121416" Foreground="White">
  <Window.Styles>
    <Style Selector="Border.appbar"><Setter Property="Background" Value="#191C1F"/><Setter Property="BorderBrush" Value="#2E3338"/></Style><Style Selector="TextBlock.eyebrow"><Setter Property="FontSize" Value="10"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="#949CA5"/><Setter Property="LetterSpacing" Value="0.8"/></Style>
    <Style Selector="Button.command"><Setter Property="Height" Value="30"/><Setter Property="Padding" Value="10,4"/><Setter Property="FontSize" Value="12"/><Setter Property="Foreground" Value="#F5F7FA"/><Setter Property="Background" Value="#252A2F"/><Setter Property="BorderBrush" Value="#3C434B"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="5"/></Style><Style Selector="Button.command /template/ ContentPresenter"><Setter Property="Background" Value="#252A2F"/><Setter Property="BorderBrush" Value="#3C434B"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="5"/></Style><Style Selector="Button.command:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="#343B42"/><Setter Property="BorderBrush" Value="#5C6670"/></Style><Style Selector="Button.primary /template/ ContentPresenter"><Setter Property="Background" Value="#F3F5F7"/><Setter Property="BorderBrush" Value="#FFFFFF"/><Setter Property="TextElement.Foreground" Value="#121416"/></Style>
    <Style Selector="Path.icon"><Setter Property="Width" Value="15"/><Setter Property="Height" Value="15"/><Setter Property="Stretch" Value="Uniform"/><Setter Property="Fill" Value="White"/></Style><Style Selector="Button.primary Path.icon"><Setter Property="Fill" Value="#121416"/></Style><Style Selector="Button.nav"><Setter Property="Width" Value="38"/><Setter Property="Height" Value="38"/><Setter Property="Padding" Value="0"/><Setter Property="Background" Value="#20252A"/><Setter Property="BorderBrush" Value="#3C434B"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="19"/></Style><Style Selector="Button.nav Path"><Setter Property="Stroke" Value="White"/><Setter Property="StrokeThickness" Value="2"/><Setter Property="StrokeLineCap" Value="Round"/></Style>
  </Window.Styles>
  <Grid RowDefinitions="Auto,*,Auto">
    <Border Grid.Row="0" Classes="appbar" BorderThickness="0,0,0,1" Padding="16,10"><Grid ColumnDefinitions="Auto,*,Auto"><StackPanel Spacing="2"><TextBlock Text="THEME" Classes="eyebrow"/><TextBlock Name="ThemeNameLabel" Text="No theme selected" FontSize="17" FontWeight="SemiBold" MaxWidth="340" TextTrimming="CharacterEllipsis"/></StackPanel><Button Grid.Column="2" Name="ReloadButton" Classes="command" Click="OnReloadClick" VerticalAlignment="Center"><StackPanel Orientation="Horizontal" Spacing="6"><Path Classes="icon" Data="M12,5 V2 L15,5 M13,8 A5,5 0 1,1 11,3"/><TextBlock Text="Reload themes"/></StackPanel></Button></Grid></Border>
    <Grid Name="PreviewGrid" Grid.Row="1" Margin="16,12" ClipToBounds="False"><Border Name="PreviewBorder" Background="#0B0D0F" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8" ClipToBounds="True"><Grid RowDefinitions="Auto,*"><Border Background="#15191D" BorderBrush="#2A3036" BorderThickness="0,0,0,1" Padding="12,8"><DockPanel><TextBlock Text="THEME PREVIEW" Classes="eyebrow"/><TextBlock DockPanel.Dock="Right" Text="Applied to the Docklys interface" FontSize="11" Foreground="#949CA5"/></DockPanel></Border><ContentControl Name="PreviewSlot" Grid.Row="1" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/></Grid></Border><Button Name="ScrollLeftButton" Classes="nav" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-19,0,0,0" Click="OnPrevClick" ToolTip.Tip="Previous theme"><Path Data="M11,4 L5,10 L11,16"/></Button><Button Name="ScrollRightButton" Classes="nav" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-19,0" Click="OnNextClick" ToolTip.Tip="Next theme"><Path Data="M5,4 L11,10 L5,16"/></Button></Grid>
    <Border Grid.Row="2" Classes="appbar" BorderThickness="0,1,0,0" Padding="16,10"><Grid ColumnDefinitions="Auto,*,Auto"><Button Name="ApplyButton" Classes="command primary" Click="OnApplyClick" HorizontalAlignment="Left"><StackPanel Orientation="Horizontal" Spacing="6"><Path Classes="icon" Data="M8,2 L12,6 L8,10 L8,7 L3,7 L3,5 L8,5 Z M4,10 L4,13 L12,13 L12,10 L14,10 L14,15 L2,15 L2,10 Z"/><TextBlock Text="Apply to Docklys"/></StackPanel></Button><StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6"><Button Classes="command" Click="CaptureToWebP_Click"><StackPanel Orientation="Horizontal" Spacing="6"><Path Classes="icon" Data="M3,2 H10 L13,5 V14 H3 Z M5,2 V6 H11 V2 M5,10 H11"/><TextBlock Text="Save preview"/></StackPanel></Button><Button Name="GitHubButton" Classes="command" Content="Repository" Click="OnGitHubClick"/><Button Classes="command" Content="More actions"><Button.Flyout><MenuFlyout Placement="Top"><MenuItem Header="Capture Docklys" Click="CaptureDock_Click"/><Separator/><MenuItem Header="Open theme images" Click="OnOpenWebPFolderClick"/><MenuItem Header="Open theme library" Click="OnOpenThemeFolderClick"/><Separator/><MenuItem Header="Theme information" Click="OnInfoClick"/><MenuItem Header="Manage images" Click="OnImagesClick"/><MenuItem Header="Publish theme" Click="OnPublishClick"/><Separator/><MenuItem Header="Terms of Service" Click="OpenLegalLink_Click" Tag="https://docklys.qwqc.de/terms-of-service"/><MenuItem Header="Privacy Policy" Click="OpenLegalLink_Click" Tag="https://docklys.qwqc.de/privacy-policy"/><MenuItem Header="Support &amp; FAQ" Click="OpenLegalLink_Click" Tag="https://docklys.qwqc.de/support"/></MenuFlyout></Button.Flyout></Button></StackPanel></Grid></Border>
  </Grid>
</Window>
