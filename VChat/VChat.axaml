<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="VChat.VChat"
             x:Name="VChatRoot">

    <UserControl.Styles>
        <Style>
            <Style.Resources>
                <FontFamily x:Key="PressStart2P">avares://Docklys.ModuleContracts/Assets/Fonts/PressStart2P-Regular.ttf#Press Start 2P</FontFamily>
            </Style.Resources>
        </Style>

        <Style Selector="Button.resize-btn">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="{DynamicResource ColorModuleFont}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="8">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.resize-btn:pointerover">
            <Setter Property="Background" Value="#383838"/>
        </Style>
        <Style Selector="Button.resize-btn:pressed">
            <Setter Property="Background" Value="#1E1E1E"/>
        </Style>

        <Style Selector="Button.done-btn">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Padding" Value="28,10"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ColorModuleFont}"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.done-btn:pointerover">
            <Setter Property="Background" Value="#383838"/>
        </Style>
        <Style Selector="Button.done-btn:pressed">
            <Setter Property="Background" Value="#1E1E1E"/>
        </Style>

    </UserControl.Styles>

    <Border Background="{DynamicResource ColorModuleColor}"
            Padding="0"
            Width="230"
            Height="350"
            CornerRadius="10"
            ClipToBounds="True">
        <Grid>
            <Grid x:Name="WebViewContainer"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch" />

            <!-- Accent pill in the bottom gap (below the WebView HWND edge) -->
            <Button x:Name="SettingsButton"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,1"
                    Width="28" Height="4"
                    MinWidth="0" MinHeight="0"
                    Background="{DynamicResource ColorAccent}"
                    Opacity="0.85"
                    Padding="0"
                    BorderThickness="0"
                    ZIndex="1000"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate>
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                MinWidth="0" MinHeight="0"/>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Settings overlay -->
            <Border x:Name="SettingsOverlay"
                    IsVisible="False"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="{DynamicResource ColorModuleColor}"
                    ZIndex="200">
                <Border VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Background="#1E000000"
                        BorderBrush="#18FFFFFF"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="30,24">
                    <StackPanel HorizontalAlignment="Center" Spacing="20">

                        <TextBlock Text="RESIZE"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   LetterSpacing="4"
                                   Opacity="0.35"
                                   Foreground="{DynamicResource ColorModuleFont}"
                                   HorizontalAlignment="Center"/>

                        <StackPanel Spacing="12">

                            <!-- Width row -->
                            <StackPanel Orientation="Horizontal"
                                        Spacing="12"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="W"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ColorModuleFont}"
                                           Opacity="0.4"
                                           VerticalAlignment="Center"
                                           Width="14"
                                           TextAlignment="Center"/>
                                <Button x:Name="WidthMinus" Content="−" Classes="resize-btn"/>
                                <TextBlock x:Name="WidthDisplay"
                                           Width="40"
                                           TextAlignment="Center"
                                           Foreground="{DynamicResource ColorModuleFont}"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="WidthPlus" Content="+" Classes="resize-btn"/>
                            </StackPanel>

                            <!-- Height row -->
                            <StackPanel Orientation="Horizontal"
                                        Spacing="12"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="H"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ColorModuleFont}"
                                           Opacity="0.4"
                                           VerticalAlignment="Center"
                                           Width="14"
                                           TextAlignment="Center"/>
                                <Button x:Name="HeightMinus" Content="−" Classes="resize-btn"/>
                                <TextBlock x:Name="HeightDisplay"
                                           Width="40"
                                           TextAlignment="Center"
                                           Foreground="{DynamicResource ColorModuleFont}"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="HeightPlus" Content="+" Classes="resize-btn"/>
                            </StackPanel>

                        </StackPanel>

                        <!-- DONE -->
                        <Button x:Name="CloseSettingsButton"
                                Classes="done-btn"
                                Content="DONE"
                                Margin="0,4,0,0"/>

                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Border>
</UserControl>
