<Window xmlns="https://github.com/avaloniaui"
        xmlns:ic="using:FluentIcons.Avalonia"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="560"
        x:Class="RunModule.MainWindow" Title="Module Editor - Docklys"
        Width="900" Height="560" MinWidth="560" MinHeight="360"
        WindowStartupLocation="CenterScreen" RequestedThemeVariant="Dark"
        Background="#121416" Foreground="White">
    <Window.Resources>
        <ControlTheme x:Key="ZoomSliderRepeatTheme" TargetType="RepeatButton"><Setter Property="Template"><ControlTemplate><Border Height="3" Background="{TemplateBinding Background}" CornerRadius="2"/></ControlTemplate></Setter></ControlTheme>
        <ControlTheme x:Key="ZoomSliderThumbTheme" TargetType="Thumb"><Setter Property="Template"><ControlTemplate><Border Width="12" Height="12" Background="#FFFFFF" BorderBrush="#D7DCE1" BorderThickness="1" CornerRadius="6"/></ControlTemplate></Setter></ControlTheme>
        <ControlTheme x:Key="ZoomSliderTheme" TargetType="Slider"><Setter Property="Template"><ControlTemplate><Grid Height="18"><Track Name="PART_Track" Minimum="{TemplateBinding Minimum}" Maximum="{TemplateBinding Maximum}" Value="{TemplateBinding Value, Mode=TwoWay}" Orientation="Horizontal" VerticalAlignment="Center"><Track.DecreaseButton><RepeatButton IsHitTestVisible="False" Background="#FFFFFF" Theme="{StaticResource ZoomSliderRepeatTheme}"/></Track.DecreaseButton><Thumb Name="SliderThumb" Theme="{StaticResource ZoomSliderThumbTheme}"/><Track.IncreaseButton><RepeatButton IsHitTestVisible="False" Background="#4E5862" Theme="{StaticResource ZoomSliderRepeatTheme}"/></Track.IncreaseButton></Track></Grid></ControlTemplate></Setter></ControlTheme>
    </Window.Resources>
    <Window.Styles>
        <Style Selector="Border.app-bar"><Setter Property="Background" Value="#191C1F"/><Setter Property="BorderBrush" Value="#2E3338"/></Style>
        <Style Selector="TextBlock.eyebrow"><Setter Property="FontSize" Value="10"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="#949CA5"/><Setter Property="LetterSpacing" Value="0.8"/></Style>
        <Style Selector="Button.command"><Setter Property="Height" Value="30"/><Setter Property="Padding" Value="10,4"/><Setter Property="FontSize" Value="12"/><Setter Property="Foreground" Value="#F5F7FA"/><Setter Property="Background" Value="#252A2F"/><Setter Property="BorderBrush" Value="#3C434B"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="5"/></Style>
        <Style Selector="Button.command /template/ ContentPresenter"><Setter Property="Background" Value="#252A2F"/><Setter Property="BorderBrush" Value="#3C434B"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="5"/></Style>
        <Style Selector="Button.command:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="#343B42"/><Setter Property="BorderBrush" Value="#5C6670"/></Style>
        <Style Selector="Button.command:pressed /template/ ContentPresenter"><Setter Property="Background" Value="#1A1E22"/></Style>
        <Style Selector="Button.command:disabled /template/ ContentPresenter"><Setter Property="Background" Value="#1C2024"/><Setter Property="BorderBrush" Value="#2C3136"/><Setter Property="TextElement.Foreground" Value="#68717A"/></Style>
        <Style Selector="Button.primary /template/ ContentPresenter"><Setter Property="Background" Value="#F3F5F7"/><Setter Property="BorderBrush" Value="#FFFFFF"/><Setter Property="TextElement.Foreground" Value="#121416"/></Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="#D8DDE2"/><Setter Property="BorderBrush" Value="#FFFFFF"/></Style>
        <Style Selector="ToggleButton.command"><Setter Property="Height" Value="30"/><Setter Property="Padding" Value="10,4"/><Setter Property="FontSize" Value="12"/><Setter Property="Foreground" Value="#F5F7FA"/><Setter Property="Background" Value="#252A2F"/><Setter Property="BorderBrush" Value="#3C434B"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="5"/></Style>
        <Style Selector="ToggleButton.command /template/ ContentPresenter"><Setter Property="Background" Value="#252A2F"/><Setter Property="BorderBrush" Value="#3C434B"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="5"/></Style>
        <Style Selector="ToggleButton.command:checked /template/ ContentPresenter"><Setter Property="Background" Value="#48515A"/><Setter Property="BorderBrush" Value="#D7DCE1"/></Style>
        <Style Selector="Path.icon"><Setter Property="Width" Value="15"/><Setter Property="Height" Value="15"/><Setter Property="Stretch" Value="Uniform"/><Setter Property="Fill" Value="Transparent"/><Setter Property="Stroke" Value="#FFFFFF"/><Setter Property="StrokeThickness" Value="1.5"/><Setter Property="StrokeLineCap" Value="Round"/></Style>
        <Style Selector="Button.primary Path.icon"><Setter Property="Stroke" Value="#121416"/></Style>
        <Style Selector="Button.nav"><Setter Property="Width" Value="32"/><Setter Property="Height" Value="52"/><Setter Property="Padding" Value="0"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderBrush" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/><Setter Property="CornerRadius" Value="0"/></Style>
        <Style Selector="Button.nav /template/ ContentPresenter"><Setter Property="Background" Value="Transparent"/><Setter Property="BorderBrush" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/></Style>
        <Style Selector="Button.nav:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="Transparent"/></Style>
        <Style Selector="Button.nav Path"><Setter Property="Stroke" Value="#DCE1E6"/><Setter Property="StrokeThickness" Value="2.4"/><Setter Property="StrokeLineCap" Value="Round"/></Style>
        <Style Selector="Button.nav:pointerover Path"><Setter Property="Stroke" Value="White"/></Style>
        <Style Selector="Border.delete"><Setter Property="Height" Value="30"/><Setter Property="Background" Value="#2C2527"/><Setter Property="BorderBrush" Value="#674B50"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="5"/><Setter Property="Cursor" Value="Hand"/></Style>
        <Style Selector="ComboBox#SkinComboBox"><Setter Property="Height" Value="30"/><Setter Property="MinWidth" Value="120"/><Setter Property="FontSize" Value="12"/><Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="#252A2F"/><Setter Property="BorderBrush" Value="#3C434B"/><Setter Property="Padding" Value="8,3"/></Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0" Classes="app-bar" BorderThickness="0,0,0,1" Padding="16,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="MODULE" Classes="eyebrow"/>
                    <TextBlock Name="ActiveModuleNameLabel" Text="No module selected" FontSize="17" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="260"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button Name="GitHubButton" Classes="command" Content="GitHub repository" Click="OnGitHubClick" ToolTip.Tip="Create or update the module's GitHub repository"/>
                    <Button Name="GitHubPullButton" Classes="command" Content="Pull" Click="OnGitHubPullClick" ToolTip.Tip="Safely fast-forward the selected module from GitHub" IsVisible="False"/>
                    <TextBlock Name="GitHubAheadNotice" Foreground="#F0C36A" FontSize="11" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="210" IsVisible="False"/>
                    <Button Name="NewButton" Classes="command" Click="CreateModule_Click" ToolTip.Tip="Create a module"><StackPanel Orientation="Horizontal" Spacing="6"><ic:FluentIcon Icon="Add" IconVariant="Regular" FontSize="16" Foreground="White"/><TextBlock Text="New module"/></StackPanel></Button>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="Zoom" Foreground="#AAB2BB" FontSize="11" VerticalAlignment="Center"/>
                        <Slider Name="ZoomSlider" Theme="{StaticResource ZoomSliderTheme}" Width="100" Minimum="25" Maximum="200" Value="100" ValueChanged="ZoomSlider_ValueChanged" ToolTip.Tip="Preview zoom; snaps to real Docklys tile layouts"/>
                        <TextBlock Name="ZoomLabel" Text="100%" Width="82" FontSize="11" VerticalAlignment="Center"/>
                        <Button Name="MainAppSizeButton" Classes="command" Content="Dock tile layout" Click="CycleMainAppSize_Click" ToolTip.Tip="Cycle the real Docklys layouts: 3 to 8 tiles per row"/>
                    </StackPanel>
                    <Button Name="RenameButton" Classes="command" Click="RenameModule_Click" ToolTip.Tip="Rename the current module"><StackPanel Orientation="Horizontal" Spacing="6"><ic:FluentIcon Icon="Edit" IconVariant="Regular" FontSize="16" Foreground="White"/><TextBlock Text="Rename"/></StackPanel></Button>
                    <Button Name="TileSizeButton" Classes="command" Click="ChangeTileSize_Click" ToolTip.Tip="Set the module tile size"><StackPanel Orientation="Horizontal" Spacing="6"><ic:FluentIcon Icon="Grid" IconVariant="Regular" FontSize="16" Foreground="White"/><TextBlock Text="Tile size"/></StackPanel></Button>
                    <Border Name="DeleteButton" Classes="delete" Width="104" PointerPressed="DeleteButton_PointerPressed" PointerReleased="DeleteButton_PointerReleased" PointerCaptureLost="DeleteButton_PointerCaptureLost" ToolTip.Tip="Hold to delete this module">
                        <Grid ClipToBounds="True"><Border Name="DeleteChargeFill" HorizontalAlignment="Left" Background="#715158" Width="0"/><StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center" VerticalAlignment="Center"><ic:FluentIcon Icon="Delete" IconVariant="Regular" FontSize="15" Foreground="White"/><TextBlock Name="DeleteButtonLabel" Text="Hold delete" FontSize="11"/></StackPanel></Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Name="PreviewGrid" Grid.Row="1" Margin="16,12" ClipToBounds="False">
            <Border Background="#0B0D0F" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                <Grid RowDefinitions="Auto,*">
                    <Border Background="#15191D" BorderBrush="#2A3036" BorderThickness="0,0,0,1" Padding="12,8">
                        <DockPanel>
                            <TextBlock Text="LIVE PREVIEW" Classes="eyebrow" VerticalAlignment="Center"/>
                            <TextBlock DockPanel.Dock="Right" Text="Use the arrows to change module" FontSize="11" Foreground="#949CA5" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                    <StackPanel Name="ModulePreviewPanel" Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
                        <ContentControl Name="ActiveModuleSlot"/>
                        <ContentControl Name="SecondModuleSlot" IsVisible="False"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Button Name="ScrollLeftButton" Classes="nav" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="14,0,0,0" Click="ScrollLeft_Click" ToolTip.Tip="Previous module"><Path Data="M11,4 L5,10 L11,16"/></Button>
            <Button Name="ScrollRightButton" Classes="nav" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0" Click="ScrollRight_Click" ToolTip.Tip="Next module"><Path Data="M5,4 L11,10 L5,16"/></Button>
            <Border Name="ThemeSettingsOverlay" ZIndex="5" IsVisible="False" Background="#E915191D" BorderBrush="#5A646E" BorderThickness="1" CornerRadius="8" Padding="18" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                <StackPanel Spacing="10">
                    <TextBlock Text="Theme library" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="Choose a Docklys skin or adjust the color resources used by this preview." Foreground="#A9B1BA" FontSize="12" TextWrapping="Wrap"/>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <TextBlock Text="Skin" Foreground="#AAB2BB" FontSize="11" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" Name="SkinComboBox" HorizontalAlignment="Stretch" SelectionChanged="SkinComboBox_SelectionChanged" ToolTip.Tip="Preview the module with a Docklys skin"/>
                    </Grid>
                    <StackPanel Name="ThemeColorsContainer" Spacing="6"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6"><Button Classes="command" Content="Reset" Click="ResetTheme_Click"/><Button Classes="command" Content="Close" Click="CloseTheme_Click"/></StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Classes="app-bar" BorderThickness="0,1,0,0" Padding="16,10">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Name="BuildDeployButton" Classes="command primary" Click="BuildAndDeploy_Click" ToolTip.Tip="Build and install this module in Docklys"><StackPanel Orientation="Horizontal" Spacing="6"><Path Classes="icon" Data="M8,1 L3,9 H7 L6,15 L13,6 H9 Z"/><TextBlock Text="Build &amp; install"/></StackPanel></Button>
                <Button Name="ReloadButton" Classes="command" Click="ReloadModule_Click" ToolTip.Tip="Reload the current module"><StackPanel Orientation="Horizontal" Spacing="6"><ic:FluentIcon Icon="ArrowClockwise" IconVariant="Regular" FontSize="16" Foreground="White"/><TextBlock Text="Reload"/></StackPanel></Button>
                <Button Name="DocklyLifecycleButton" Classes="command" Click="DocklyLifecycle_Click" ToolTip.Tip="Start or stop Docklys"><StackPanel Orientation="Horizontal" Spacing="6"><ic:FluentIcon Icon="Play" IconVariant="Regular" FontSize="16" Foreground="White"/><TextBlock Text="Docklys"/></StackPanel></Button>
                <Button Name="ThemeButton" Classes="command" Click="ThemeButton_Click" ToolTip.Tip="Choose a skin or edit preview colors"><StackPanel Orientation="Horizontal" Spacing="6"><ic:FluentIcon Icon="Color" IconVariant="Regular" FontSize="16" Foreground="White"/><TextBlock Text="Theme library"/></StackPanel></Button>
                <Button Classes="command" Click="CaptureToWebP_Click" ToolTip.Tip="Save a preview image"><StackPanel Orientation="Horizontal" Spacing="6"><ic:FluentIcon Icon="Image" IconVariant="Regular" FontSize="16" Foreground="White"/><TextBlock Text="Save preview"/></StackPanel></Button>
                <Button Classes="command" Content="Testing" ToolTip.Tip="Preview module behavior">
                    <Button.Flyout>
                        <Flyout Placement="Top">
                            <StackPanel Spacing="6" MinWidth="190">
                                <TextBlock Text="TESTING" Classes="eyebrow" Margin="4,2"/>
                                <ToggleButton Name="DualViewButton" Classes="command" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Content="Show two modules" Click="ToggleDualView_Click" ToolTip.Tip="Preview two module instances side by side"/>
                                <ToggleButton Name="SlidePreviewButton" Classes="command" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Content="Play slide animation" IsCheckedChanged="SlidePreviewButton_IsCheckedChanged" ToolTip.Tip="Loop the Docklys slide-in and slide-out animation"/>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Button Classes="command" Content="Files"><Button.Flyout><MenuFlyout Placement="Top"><MenuItem Header="Capture Docklys" Click="CaptureDock_Click"/><MenuItem Header="Open preview images" Click="OpenWebPFolder_Click"/><MenuItem Header="Open build output" Click="OpenOutputModuleDllFolder_Click"/><MenuItem Header="Open installed modules" Click="OpenDocklyModulesFolder_Click"/><MenuItem Header="Open module saves" Click="OpenSavesFolder_Click"/></MenuFlyout></Button.Flyout></Button>
                <Button Classes="command" Content="Project"><Button.Flyout><MenuFlyout Placement="Top"><MenuItem Header="Module information" Click="OnInfoClick"/><MenuItem Header="Permissions" Click="OnPermissionsClick"/><MenuItem Header="Change license" Click="OnLicenseClick"/><MenuItem Header="Publish module" Click="OnPublishClick"/></MenuFlyout></Button.Flyout></Button>
                <Button Classes="command" Content="Help &amp; legal"><Button.Flyout><MenuFlyout Placement="Top"><MenuItem Header="Terms of Service" Click="OpenLegalLink_Click" Tag="https://docklys.qwqc.de/terms-of-service"/><MenuItem Header="Privacy Policy" Click="OpenLegalLink_Click" Tag="https://docklys.qwqc.de/privacy-policy"/><MenuItem Header="Support &amp; FAQ" Click="OpenLegalLink_Click" Tag="https://docklys.qwqc.de/support"/></MenuFlyout></Button.Flyout></Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
