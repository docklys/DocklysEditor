<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:VolumeMixer="clr-namespace:VolumeMixer;assembly=VolumeMixer"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="RunModule.MainWindow"
        Title="RunModule"
        SizeToContent="Manual"
        WindowStartupLocation="Manual">
    <Window.Styles>
        <!-- Local styles scoped to the ZoomSlider only to avoid affecting module styles -->
        <Style Selector="Slider#ZoomSlider /template/ Thumb">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}" />
                </ControlTemplate>
            </Setter>
            <Setter Property="Background" Value="#333333" />
            <Setter Property="BorderBrush" Value="#777777" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="10" />
        </Style>

        <Style Selector="Slider#ZoomSlider">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#555555" />
        </Style>
    </Window.Styles>
    <Grid RowDefinitions="*, Auto">
        <!-- Main content area: module control with an overlay in the top-right for controls -->
        <Grid Grid.Row="0">
            <!-- The module user control -->
            <VolumeMixer:VolumeMixer Name="ModuleControl" HorizontalAlignment="Center" VerticalAlignment="Center" />

            <!-- Top-right overlay containing only the zoom slider and percentage label -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="8"
                        Spacing="6">
                <!-- Zoom slider + percentage label -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                    <!-- Dark-themed slider: neutral greys only -->
                    <Slider Name="ZoomSlider"
                            Minimum="100"
                            Maximum="300"
                            Value="100"
                            Width="160"
                            Background="#1A1A1A"
                            Foreground="White"
                            BorderBrush="#555555"
                            ValueChanged="ZoomSlider_ValueChanged" />
                    <TextBlock Name="ZoomLabel" Text="100%" VerticalAlignment="Center" Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Compact control row: smaller buttons, no hover tips, tighter spacing -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8" Margin="0,10">
            <!-- Let buttons size to content so text is always visible; compact heights retained -->
            <Button Content="↺ Reload Module"
                    Foreground="White"
                    Click="ReloadModule_Click"
                    Height="28"
                    FontSize="11"
                    Padding="8,2"/>
            <Button Content="Save WebP"
                    Foreground="White"
                    Click="CaptureToWebP_Click"
                    Height="28"
                    FontSize="11"
                    Padding="8,2"/>
            <Button Content="Open WebP"
                    Foreground="White"
                    Click="OpenWebPFolder_Click"
                    Height="28"
                    FontSize="11"
                    Padding="8,2"/>
            <Button Content="Open DLLs"
                    Foreground="White"
                    Click="OpenOutputModuleDllFolder_Click"
                    Height="28"
                    FontSize="11"
                    Padding="8,2"/>
        </StackPanel>
    </Grid>
</Window>