<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="776" d:DesignHeight="338"
        x:Class="RunModule.MainWindow"
        Title="RunModule"
        Width="776"
        Height="338"
        MinWidth="450"
        MinHeight="225"
        SizeToContent="Manual"
        WindowStartupLocation="CenterScreen"
        RequestedThemeVariant="Dark"
        Background="#1A1A1A"
        Foreground="White">
    <Window.Resources>
        <!-- Re-point Avalonia's Fluent accent palette to neutral grays so
             the theme's default blue/teal highlights (focus rings, slider
             progress, ComboBox selection accents, etc.) come out
             monochrome to match the rest of the chrome. -->
        <Color x:Key="SystemAccentColor">#888888</Color>
        <Color x:Key="SystemAccentColorLight1">#9A9A9A</Color>
        <Color x:Key="SystemAccentColorLight2">#ABABAB</Color>
        <Color x:Key="SystemAccentColorLight3">#BCBCBC</Color>
        <Color x:Key="SystemAccentColorDark1">#777777</Color>
        <Color x:Key="SystemAccentColorDark2">#666666</Color>
        <Color x:Key="SystemAccentColorDark3">#555555</Color>
    </Window.Resources>
    <Window.Styles>
        <!-- Zoom slider thumb: solid white pill to match the b/w palette. -->
        <Style Selector="Slider#ZoomSlider /template/ Thumb">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}" />
                </ControlTemplate>
            </Setter>
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#777777" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="10" />
        </Style>
        <Style Selector="Slider#ZoomSlider">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#555555" />
        </Style>

        <!-- Section dividers between top toolbar / preview / bottom toolbar. -->
        <Style Selector="Border.toolbar-bar">
            <Setter Property="Background" Value="#202020" />
            <Setter Property="BorderBrush" Value="#2F2F2F" />
        </Style>

        <!-- Captions / muted labels above grouped controls. -->
        <Style Selector="TextBlock.caption">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="#888888" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Carousel arrow buttons: chrome-free, just clean white chevrons. -->
        <Style Selector="Button.scroll-arrow">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.scroll-arrow /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Button.scroll-arrow:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Button.scroll-arrow:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Button.scroll-arrow Path">
            <Setter Property="Stroke" Value="White" />
            <Setter Property="StrokeThickness" Value="2.5" />
            <Setter Property="StrokeLineCap" Value="Round" />
            <Setter Property="StrokeJoin" Value="Round" />
        </Style>
        <Style Selector="Button.scroll-arrow:pointerover Path">
            <Setter Property="StrokeThickness" Value="3.5" />
        </Style>

        <!-- Dev toolbar buttons share a compact monochrome look. -->
        <Style Selector="Button.toolbar">
            <Setter Property="Height" Value="26" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="10,2" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="Button.toolbar /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="Button.toolbar:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3D3D3D" />
            <Setter Property="BorderBrush" Value="#777777" />
            <Setter Property="TextElement.Foreground" Value="White" />
        </Style>
        <Style Selector="Button.toolbar:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="TextElement.Foreground" Value="White" />
        </Style>
        <Style Selector="Button.toolbar:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#222222" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="TextElement.Foreground" Value="#666666" />
        </Style>

        <!-- The "primary" call-to-action: the deploy button. Lighter bg
             so it reads as the headline action without breaking the
             monochrome palette. -->
        <Style Selector="Button.toolbar.primary /template/ ContentPresenter">
            <Setter Property="Background" Value="#4A4A4A" />
            <Setter Property="BorderBrush" Value="#888888" />
        </Style>
        <Style Selector="Button.toolbar.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#5C5C5C" />
            <Setter Property="BorderBrush" Value="#AAAAAA" />
        </Style>
        <Style Selector="Button.toolbar.primary:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#383838" />
            <Setter Property="BorderBrush" Value="#888888" />
        </Style>

        <!-- Hold-to-charge delete widget. -->
        <Style Selector="Border.delete-btn">
            <Setter Property="Height" Value="26" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Background" Value="#3A3A3A" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Skin picker matches the toolbar buttons. -->
        <Style Selector="ComboBox#SkinComboBox">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Height" Value="26" />
        </Style>
        <Style Selector="ComboBox#SkinComboBox /template/ Border#Background">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="BorderBrush" Value="#555555" />
        </Style>
        <Style Selector="ComboBox#SkinComboBox:pointerover /template/ Border#Background">
            <Setter Property="Background" Value="#3D3D3D" />
            <Setter Property="BorderBrush" Value="#777777" />
        </Style>
        <Style Selector="ComboBox#SkinComboBox:pressed /template/ Border#Background">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="BorderBrush" Value="#555555" />
        </Style>
        <Style Selector="ComboBox#SkinComboBox:focus /template/ Border#Background">
            <Setter Property="BorderBrush" Value="#888888" />
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style Selector="ComboBoxItem /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2A2A" />
        </Style>
        <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3D3D3D" />
            <Setter Property="TextElement.Foreground" Value="White" />
        </Style>
        <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#4A4A4A" />
            <Setter Property="TextElement.Foreground" Value="White" />
        </Style>
        <Style Selector="ComboBoxItem:selected:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#555555" />
            <Setter Property="TextElement.Foreground" Value="White" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- ═════════ Top bar: identity | view | skin ═════════ -->
        <Border Grid.Row="0"
                Classes="toolbar-bar"
                BorderThickness="0,0,0,1"
                Padding="10,6">
            <Grid ColumnDefinitions="Auto, *, Auto">

                <!-- Module identity + per-module actions -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Name="ActiveModuleNameLabel"
                               Text="(no module)"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="White"
                               VerticalAlignment="Center"
                               MinWidth="80"/>
                    <Button Name="RenameButton"
                            Classes="toolbar"
                            Content="✎ Rename"
                            Click="RenameModule_Click"
                            ToolTip.Tip="Rename the currently displayed module" />

                    <!-- Hold-to-charge delete (Border, not Button — we drive
                         PointerPressed / Released ourselves so the Button
                         Click handler doesn't interfere). -->
                    <Border Name="DeleteButton"
                            Classes="delete-btn"
                            Width="130"
                            PointerPressed="DeleteButton_PointerPressed"
                            PointerReleased="DeleteButton_PointerReleased"
                            PointerCaptureLost="DeleteButton_PointerCaptureLost"
                            ToolTip.Tip="Press and HOLD to charge a deletion, then enter 1234 to confirm">
                        <Grid ClipToBounds="True">
                            <Border Name="DeleteChargeFill"
                                    HorizontalAlignment="Left"
                                    Background="#888888"
                                    Width="0" />
                            <TextBlock Name="DeleteButtonLabel"
                                       Text="✕ Hold to delete"
                                       FontSize="11"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Center: zoom -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="6">
                    <TextBlock Text="Zoom" Classes="caption"/>
                    <Slider Name="ZoomSlider"
                            Minimum="100"
                            Maximum="300"
                            Value="100"
                            Width="140"
                            ValueChanged="ZoomSlider_ValueChanged"
                            VerticalAlignment="Center"/>
                    <TextBlock Name="ZoomLabel"
                               Text="100%"
                               FontSize="11"
                               Foreground="White"
                               VerticalAlignment="Center"
                               MinWidth="34"/>
                </StackPanel>

                <!-- Right: skin -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="Skin" Classes="caption"/>
                    <ComboBox Name="SkinComboBox"
                              MinWidth="120"
                              SelectionChanged="SkinComboBox_SelectionChanged"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═════════ Module preview: one slot + cycle arrows ═════════ -->
        <Grid Grid.Row="1">
            <ContentControl Name="ActiveModuleSlot"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
            <Button Name="ScrollLeftButton"
                    Classes="scroll-arrow"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="10,0,0,0"
                    IsVisible="False"
                    Click="ScrollLeft_Click"
                    ToolTip.Tip="Previous module">
                <Path Data="M 12 0 L 0 16 L 12 32" />
            </Button>
            <Button Name="ScrollRightButton"
                    Classes="scroll-arrow"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,10,0"
                    IsVisible="False"
                    Click="ScrollRight_Click"
                    ToolTip.Tip="Next module">
                <Path Data="M 0 0 L 12 16 L 0 32" />
            </Button>
        </Grid>

        <!-- ═════════ Bottom bar: lifecycle | deploy | artifacts ═════════
             Three logical groups, separated by elastic gaps. Lifecycle on
             the left (Create/Reload), the headline deploy action centered
             and styled as primary, and artifact ops aligned right.        -->
        <Border Grid.Row="2"
                Classes="toolbar-bar"
                BorderThickness="0,1,0,0"
                Padding="10,6">
            <Grid ColumnDefinitions="Auto, *, Auto, *, Auto">

                <!-- Module lifecycle -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button Classes="toolbar"
                            Content="✚ New"
                            Click="CreateModule_Click"
                            ToolTip.Tip="Scaffold a new module by cloning DefaultModule"/>
                    <Button Classes="toolbar"
                            Content="↺ Reload"
                            Click="ReloadModule_Click"
                            ToolTip.Tip="Re-instantiate the active module"/>
                </StackPanel>

                <!-- Deploy (center, primary styling) -->
                <Button Grid.Column="2"
                        Name="BuildDeployButton"
                        Classes="toolbar primary"
                        Content="⚡ Push to Docklys"
                        Click="BuildAndDeploy_Click"
                        ToolTip.ShowDelay="200"/>

                <!-- Artifacts -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button Classes="toolbar"
                            Content="Save .webp"
                            Click="CaptureToWebP_Click"
                            ToolTip.Tip="Save a screenshot of the active module"/>
                    <Button Classes="toolbar"
                            Content="📂 .webp"
                            Click="OpenWebPFolder_Click"
                            ToolTip.Tip="Open the OutputWebPModule folder"/>
                    <Button Classes="toolbar"
                            Content="📂 .dll"
                            Click="OpenOutputModuleDllFolder_Click"
                            ToolTip.Tip="Open the OutputModuleDLL folder"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
