<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="560"
        x:Class="RunModule.MainWindow" Title="Module Editor - Docklys"
        Width="900" Height="560" MinWidth="560" MinHeight="360"
        WindowStartupLocation="CenterScreen" RequestedThemeVariant="Dark"
        Background="#121416" Foreground="White">
    <Window.Styles>
        <Style Selector="Border.app-bar"><Setter Property="Background" Value="#191C1F"/><Setter Property="BorderBrush" Value="#2E3338"/></Style>
        <Style Selector="TextBlock.eyebrow"><Setter Property="FontSize" Value="10"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="#949CA5"/><Setter Property="LetterSpacing" Value="0.8"/></Style>
        <Style Selector="Button.command"><Setter Property="Height" Value="30"/><Setter Property="Padding" Value="10,4"/><Setter Property="FontSize" Value="12"/><Setter Property="Foreground" Value="#F5F7FA"/><Setter Property="Background" Value="#252A2F"/><Setter Property="BorderBrush" Value="#3C434B"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="5"/></Style>
        <Style Selector="Button.command /template/ ContentPresenter"><Setter Property="Background" Value="#252A2F"/><Setter Property="BorderBrush" Value="#3C434B"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="5"/></Style>
        <Style Selector="Button.command:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="#343B42"/><Setter Property="BorderBrush" Value="#5C6670"/></Style>
        <Style Selector="Button.command:pressed /template/ ContentPresenter"><Setter Property="Background" Value="#1A1E22"/></Style>
        <Style Selector="Button.command:disabled /template/ ContentPresenter"><Setter Property="Background" Value="#1C2024"/><Setter Property="BorderBrush" Value="#2C3136"/><Setter Property="TextElement.Foreground" Value="#68717A"/></Style>
        <Style Selector="Button.primary /template/ ContentPresenter"><Setter Property="Background" Value="#F3F5F7"/><Setter Property="BorderBrush" Value="#FFFFFF"/><Setter Property="TextElement.Foreground" Value="#121416"/></Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="#D8DDE2"/><Setter Property="BorderBrush" Value="#FFFFFF"/></Style>
        <Style Selector="ToggleButton.command"><Setter Property="Height" Value="30"/><Setter Property="Padding" Value="10,4"/><Setter Property="FontSize" Value="12"/><Setter Property="Foreground" Value="#F5F7FA"/><Setter Property="Background" Value="#252A2F"/><Setter Property="BorderBrush" Value="#3C434B"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="5"/></Style>
        <Style Selector="ToggleButton.command /template/ ContentPresenter"><Setter Property="Background" Value="#252A2F"/><Setter Property="BorderBrush" Value="#3C434B"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="5"/></Style>
        <Style Selector="ToggleButton.command:checked /template/ ContentPresenter"><Setter Property="Background" Value="#48515A"/><Setter Property="BorderBrush" Value="#D7DCE1"/></Style>
        <Style Selector="Path.icon"><Setter Property="Width" Value="15"/><Setter Property="Height" Value="15"/><Setter Property="Stretch" Value="Uniform"/><Setter Property="Fill" Value="#FFFFFF"/></Style>
        <Style Selector="Button.primary Path.icon"><Setter Property="Fill" Value="#121416"/></Style>
        <Style Selector="Button.nav"><Setter Property="Width" Value="38"/><Setter Property="Height" Value="38"/><Setter Property="Padding" Value="0"/><Setter Property="Background" Value="#20252A"/><Setter Property="BorderBrush" Value="#3C434B"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="19"/></Style>
        <Style Selector="Button.nav:pointerover"><Setter Property="Background" Value="#343B42"/></Style>
        <Style Selector="Button.nav Path"><Setter Property="Stroke" Value="White"/><Setter Property="StrokeThickness" Value="2"/><Setter Property="StrokeLineCap" Value="Round"/></Style>
        <Style Selector="Border.delete"><Setter Property="Height" Value="30"/><Setter Property="Background" Value="#2C2527"/><Setter Property="BorderBrush" Value="#674B50"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="5"/><Setter Property="Cursor" Value="Hand"/></Style>
        <Style Selector="ComboBox#SkinComboBox"><Setter Property="Height" Value="30"/><Setter Property="MinWidth" Value="120"/><Setter Property="FontSize" Value="12"/><Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="#252A2F"/><Setter Property="BorderBrush" Value="#3C434B"/><Setter Property="Padding" Value="8,3"/></Style>
        <Style Selector="Slider#ZoomSlider /template/ Thumb"><Setter Property="Background" Value="White"/><Setter Property="Width" Value="12"/><Setter Property="Height" Value="12"/></Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0" Classes="app-bar" BorderThickness="0,0,0,1" Padding="16,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="MODULE" Classes="eyebrow"/>
                    <TextBlock Name="ActiveModuleNameLabel" Text="No module selected" FontSize="17" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="260"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button Name="RenameButton" Classes="command" Click="RenameModule_Click" ToolTip.Tip="Rename the current module"><StackPanel Orientation="Horizontal" Spacing="6"><Path Classes="icon" Data="M3,12.5 L3,15 L5.5,15 L13.8,6.7 L11.3,4.2 Z M12.2,3.3 L13.5,2 L16,4.5 L14.7,5.8 Z"/><TextBlock Text="Rename"/></StackPanel></Button>
                    <Button Name="TileSizeButton" Classes="command" Click="ChangeTileSize_Click" ToolTip.Tip="Set the module tile size"><StackPanel Orientation="Horizontal" Spacing="6"><Path Classes="icon" Data="M2,2 H7 V7 H2 Z M9,2 H14 V7 H9 Z M2,9 H7 V14 H2 Z M9,9 H14 V14 H9 Z"/><TextBlock Text="Tile size"/></StackPanel></Button>
                    <Border Name="DeleteButton" Classes="delete" Width="104" PointerPressed="DeleteButton_PointerPressed" PointerReleased="DeleteButton_PointerReleased" PointerCaptureLost="DeleteButton_PointerCaptureLost" ToolTip.Tip="Hold to delete this module">
                        <Grid ClipToBounds="True"><Border Name="DeleteChargeFill" HorizontalAlignment="Left" Background="#715158" Width="0"/><StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center" VerticalAlignment="Center"><Path Classes="icon" Data="M3,4 H13 V15 H3 Z M5,2 H11 V3 H5 Z M6,6 V12 H7 V6 Z M9,6 V12 H10 V6 Z"/><TextBlock Name="DeleteButtonLabel" Text="Hold delete" FontSize="11"/></StackPanel></Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Name="PreviewGrid" Grid.Row="1" Margin="16,12" ClipToBounds="False">
            <Border Background="#0B0D0F" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                <Grid RowDefinitions="Auto,*">
                    <Border Background="#15191D" BorderBrush="#2A3036" BorderThickness="0,0,0,1" Padding="12,8">
                        <DockPanel>
                            <TextBlock Text="LIVE PREVIEW" Classes="eyebrow" VerticalAlignment="Center"/>
                            <TextBlock DockPanel.Dock="Right" Text="Use the arrows to change module" FontSize="11" Foreground="#949CA5" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                    <StackPanel Name="ModulePreviewPanel" Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
                        <ContentControl Name="ActiveModuleSlot"/>
                        <ContentControl Name="SecondModuleSlot" IsVisible="False"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Button Name="ScrollLeftButton" Classes="nav" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-19,0,0,0" Click="ScrollLeft_Click" ToolTip.Tip="Previous module"><Path Data="M11,4 L5,10 L11,16"/></Button>
            <Button Name="ScrollRightButton" Classes="nav" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-19,0" Click="ScrollRight_Click" ToolTip.Tip="Next module"><Path Data="M5,4 L11,10 L5,16"/></Button>
            <Border Name="ThemeSettingsOverlay" ZIndex="5" IsVisible="False" Background="#E915191D" BorderBrush="#5A646E" BorderThickness="1" CornerRadius="8" Padding="18" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                <StackPanel Spacing="10"><TextBlock Text="Theme settings" FontSize="16" FontWeight="SemiBold"/><TextBlock Text="Adjust the color resources used by this preview." Foreground="#A9B1BA" FontSize="12"/><StackPanel Name="ThemeColorsContainer" Spacing="6"/><StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6"><Button Classes="command" Content="Reset" Click="ResetTheme_Click"/><Button Classes="command" Content="Close" Click="CloseTheme_Click"/></StackPanel></StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Classes="app-bar" BorderThickness="0,1,0,0" Padding="16,10">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Name="BuildDeployButton" Classes="command primary" Click="BuildAndDeploy_Click" ToolTip.Tip="Build and install this module in Docklys"><StackPanel Orientation="Horizontal" Spacing="6"><Path Classes="icon" Data="M8,1 L3,9 H7 L6,15 L13,6 H9 Z"/><TextBlock Text="Build &amp; install"/></StackPanel></Button>
                        <Button Name="DocklyLifecycleButton" Classes="command" Click="DocklyLifecycle_Click" ToolTip.Tip="Start or stop Docklys"><StackPanel Orientation="Horizontal" Spacing="6"><Path Classes="icon" Data="M4,2 L14,8 L4,14 Z"/><TextBlock Text="Docklys"/></StackPanel></Button>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                        <Button Classes="command" Click="CaptureToWebP_Click" ToolTip.Tip="Save a preview image"><StackPanel Orientation="Horizontal" Spacing="6"><Path Classes="icon" Data="M3,2 H10 L13,5 V14 H3 Z M5,2 V6 H11 V2 M5,10 H11"/><TextBlock Text="Save preview"/></StackPanel></Button>
                        <Button Name="GitHubButton" Classes="command" Content="Repository" Click="OnGitHubClick" ToolTip.Tip="Create or update the project repository"/>
                        <Button Classes="command" Content="More actions" ToolTip.Tip="Files, project details, publishing and support"><Button.Flyout><MenuFlyout Placement="Top"><MenuItem Header="Capture Docklys" Click="CaptureDock_Click"/><Separator/><MenuItem Header="Open preview images" Click="OpenWebPFolder_Click"/><MenuItem Header="Open build output" Click="OpenOutputModuleDllFolder_Click"/><MenuItem Header="Open installed modules" Click="OpenDocklyModulesFolder_Click"/><MenuItem Header="Open module saves" Click="OpenSavesFolder_Click"/><Separator/><MenuItem Header="Module information" Click="OnInfoClick"/><MenuItem Header="Manage images" Click="OnImagesClick"/><MenuItem Header="Change license" Click="OnLicenseClick"/><MenuItem Header="Publish module" Click="OnPublishClick"/><Separator/><MenuItem Header="Legal and support"><MenuItem Header="Terms of Service" Click="OpenLegalLink_Click" Tag="https://docklys.qwqc.de/terms-of-service"/><MenuItem Header="Privacy Policy" Click="OpenLegalLink_Click" Tag="https://docklys.qwqc.de/privacy-policy"/><MenuItem Header="Support &amp; FAQ" Click="OpenLegalLink_Click" Tag="https://docklys.qwqc.de/support"/></MenuItem></MenuFlyout></Button.Flyout></Button>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,Auto,*,Auto" ColumnSpacing="8">
                    <Button Name="NewButton" Classes="command" Click="CreateModule_Click" ToolTip.Tip="Create a module"><StackPanel Orientation="Horizontal" Spacing="6"><Path Classes="icon" Data="M7,2 V12 M2,7 H12"/><TextBlock Text="New module"/></StackPanel></Button>
                    <Button Grid.Column="1" Name="ReloadButton" Classes="command" Click="ReloadModule_Click" ToolTip.Tip="Reload the current module"><StackPanel Orientation="Horizontal" Spacing="6"><Path Classes="icon" Data="M12,5 V2 L15,5 M13,8 A5,5 0 1,1 11,3"/><TextBlock Text="Reload"/></StackPanel></Button>
                    <Button Grid.Column="2" Name="ThemeButton" Classes="command" Click="ThemeButton_Click" ToolTip.Tip="Edit preview theme colors"><StackPanel Orientation="Horizontal" Spacing="6"><Path Classes="icon" Data="M8,2 A6,6 0 1,0 8,14 A2,2 0 0,0 10,12 C10,11 9,10 10,9 C11,8 14,10 14,7 A5,5 0 0,0 8,2"/><TextBlock Text="Preview theme"/></StackPanel></Button>
                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"><TextBlock Text="VIEW" Classes="eyebrow" VerticalAlignment="Center"/><TextBlock Text="Zoom" Foreground="#AAB2BB" FontSize="11" VerticalAlignment="Center"/><Slider Name="ZoomSlider" Width="100" Minimum="25" Maximum="200" Value="100" ValueChanged="ZoomSlider_ValueChanged" ToolTip.Tip="Preview zoom"/><TextBlock Name="ZoomLabel" Text="100%" Width="36" FontSize="11" VerticalAlignment="Center"/><Button Name="MainAppSizeButton" Classes="command" Content="Actual size" Click="CycleMainAppSize_Click"/><ToggleButton Name="DualViewButton" Classes="command" Content="Compare" Click="ToggleDualView_Click"/><ToggleButton Name="SlidePreviewButton" Classes="command" Content="Animate" IsCheckedChanged="SlidePreviewButton_IsCheckedChanged"/><TextBlock Text="Skin" Foreground="#AAB2BB" FontSize="11" VerticalAlignment="Center"/><ComboBox Name="SkinComboBox" SelectionChanged="SkinComboBox_SelectionChanged" ToolTip.Tip="Preview the module with a Docklys skin"/></StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
