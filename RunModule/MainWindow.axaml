<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="776" d:DesignHeight="338"
        x:Class="RunModule.MainWindow"
        Title="Module Editor - Docklys"
        Width="776"
        Height="338"
        MinWidth="450"
        MinHeight="225"
        SizeToContent="Manual"
        WindowStartupLocation="CenterScreen"
        RequestedThemeVariant="Dark"
        Background="#1A1A1A"
        Foreground="White">
    <Window.Resources>
    </Window.Resources>
    <Window.Styles>
        <!-- Zoom slider thumb: solid white pill to match the b/w palette. -->
        <Style Selector="Slider#ZoomSlider /template/ Thumb">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}" />
                </ControlTemplate>
            </Setter>
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#777777" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="10" />
        </Style>
        <Style Selector="Slider#ZoomSlider">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#555555" />
        </Style>

        <!-- Section dividers between top toolbar / preview / bottom toolbar. -->
        <Style Selector="Border.toolbar-bar">
            <Setter Property="Background" Value="#202020" />
            <Setter Property="BorderBrush" Value="#2F2F2F" />
        </Style>

        <!-- Captions / muted labels above grouped controls. -->
        <Style Selector="TextBlock.caption">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="#888888" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Carousel arrow buttons: chrome-free, just clean white chevrons. -->
        <Style Selector="Button.scroll-arrow">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.scroll-arrow /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Button.scroll-arrow:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Button.scroll-arrow:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Button.scroll-arrow Path">
            <Setter Property="Stroke" Value="White" />
            <Setter Property="StrokeThickness" Value="2.5" />
            <Setter Property="StrokeLineCap" Value="Round" />
            <Setter Property="StrokeJoin" Value="Round" />
        </Style>
        <Style Selector="Button.scroll-arrow:pointerover Path">
            <Setter Property="StrokeThickness" Value="3.5" />
        </Style>

        <!-- Dev toolbar buttons share a compact monochrome look. -->
        <Style Selector="Button.toolbar">
            <Setter Property="Height" Value="26" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="10,2" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="Button.toolbar /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="Button.toolbar:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3D3D3D" />
            <Setter Property="BorderBrush" Value="#777777" />
            <Setter Property="TextElement.Foreground" Value="White" />
        </Style>
        <Style Selector="Button.toolbar:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="TextElement.Foreground" Value="White" />
        </Style>
        <Style Selector="Button.toolbar:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#222222" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="TextElement.Foreground" Value="#666666" />
        </Style>

        <!-- Dual-view toggle: full set of states so the Fluent theme's blue
             accent never bleeds through. Unchecked mirrors Button.toolbar;
             checked is slightly brighter to read as "on". -->
        <Style Selector="ToggleButton.toolbar">
            <Setter Property="Height" Value="26" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="10,2" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="ToggleButton.toolbar /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="ToggleButton.toolbar:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3D3D3D" />
            <Setter Property="BorderBrush" Value="#777777" />
            <Setter Property="TextElement.Foreground" Value="White" />
        </Style>
        <Style Selector="ToggleButton.toolbar:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="TextElement.Foreground" Value="White" />
        </Style>
        <Style Selector="ToggleButton.toolbar:checked /template/ ContentPresenter">
            <Setter Property="Background" Value="#5A5A5A" />
            <Setter Property="BorderBrush" Value="#AAAAAA" />
        </Style>
        <Style Selector="ToggleButton.toolbar:checked:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#6A6A6A" />
            <Setter Property="BorderBrush" Value="#BBBBBB" />
        </Style>
        <Style Selector="ToggleButton.toolbar:checked:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#444444" />
            <Setter Property="BorderBrush" Value="#888888" />
        </Style>

        <!-- The "primary" call-to-action: the deploy button. Lighter bg
             so it reads as the headline action without breaking the
             monochrome palette. -->
        <Style Selector="Button.toolbar.primary /template/ ContentPresenter">
            <Setter Property="Background" Value="#4A4A4A" />
            <Setter Property="BorderBrush" Value="#888888" />
        </Style>
        <Style Selector="Button.toolbar.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#5C5C5C" />
            <Setter Property="BorderBrush" Value="#AAAAAA" />
        </Style>
        <Style Selector="Button.toolbar.primary:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#383838" />
            <Setter Property="BorderBrush" Value="#888888" />
        </Style>

        <!-- Hold-to-charge delete widget. -->
        <Style Selector="Border.delete-btn">
            <Setter Property="Height" Value="26" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Background" Value="#3A3A3A" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Skin picker matches the toolbar buttons. -->
        <Style Selector="ComboBox#SkinComboBox">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Height" Value="26" />
        </Style>
        <Style Selector="ComboBox#SkinComboBox /template/ Border#Background">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="BorderBrush" Value="#555555" />
        </Style>
        <Style Selector="ComboBox#SkinComboBox:pointerover /template/ Border#Background">
            <Setter Property="Background" Value="#3D3D3D" />
            <Setter Property="BorderBrush" Value="#777777" />
        </Style>
        <Style Selector="ComboBox#SkinComboBox:pressed /template/ Border#Background">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="BorderBrush" Value="#555555" />
        </Style>
        <Style Selector="ComboBox#SkinComboBox:focus /template/ Border#Background">
            <Setter Property="BorderBrush" Value="#888888" />
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style Selector="ComboBoxItem /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2A2A" />
        </Style>
        <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3D3D3D" />
            <Setter Property="TextElement.Foreground" Value="White" />
        </Style>
        <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#4A4A4A" />
            <Setter Property="TextElement.Foreground" Value="White" />
        </Style>
        <Style Selector="ComboBoxItem:selected:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#555555" />
            <Setter Property="TextElement.Foreground" Value="White" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- ═════════ Top bar: identity | view | skin ═════════ -->
        <Border Grid.Row="0"
                Classes="toolbar-bar"
                BorderThickness="0,0,0,1"
                Padding="10,6">
            <Grid ColumnDefinitions="Auto, *, Auto">

                <!-- Module identity + per-module actions -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Name="ActiveModuleNameLabel"
                               Text="(no module)"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="White"
                               VerticalAlignment="Center"
                               MinWidth="80"/>
                    <Button Name="RenameButton"
                            Classes="toolbar"
                            Content="✎ Rename"
                            Click="RenameModule_Click"
                            ToolTip.Tip="Rename the currently displayed module" />
                    <Button Name="TileSizeButton"
                            Classes="toolbar"
                            Content="⊡ Size"
                            Click="ChangeTileSize_Click"
                            ToolTip.Tip="Change the tile width and height of the active module" />

                    <!-- Hold-to-charge delete (Border, not Button — we drive
                         PointerPressed / Released ourselves so the Button
                         Click handler doesn't interfere). -->
                    <Border Name="DeleteButton"
                            Classes="delete-btn"
                            Width="130"
                            PointerPressed="DeleteButton_PointerPressed"
                            PointerReleased="DeleteButton_PointerReleased"
                            PointerCaptureLost="DeleteButton_PointerCaptureLost"
                            ToolTip.Tip="Press and HOLD to charge a deletion, then enter 1234 to confirm">
                        <Grid ClipToBounds="True">
                            <Border Name="DeleteChargeFill"
                                    HorizontalAlignment="Left"
                                    Background="#888888"
                                    Width="0" />
                            <TextBlock Name="DeleteButtonLabel"
                                       Text="✕ Hold to delete"
                                       FontSize="11"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Center: zoom + dual-view toggle -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10">
                    <TextBlock Text="Zoom" Classes="caption"/>
                    <Slider Name="ZoomSlider"
                            Minimum="25"
                            Maximum="150"
                            Value="100"
                            Width="300"
                            ValueChanged="ZoomSlider_ValueChanged"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Drag to zoom. The slider magnetically locks onto the real sizes the module has in Docklys at each Tiles-per-row setting (3–8), marked by ticks."/>
                    <TextBlock Name="ZoomLabel"
                               Text="100%"
                               FontSize="11"
                               Foreground="White"
                               VerticalAlignment="Center"
                               MinWidth="72"/>
                    <Button Name="MainAppSizeButton"
                            Classes="toolbar"
                            Content="⊞ Real size"
                            Click="CycleMainAppSize_Click"
                            ToolTip.Tip="Snap the preview to the module's real size in Docklys. Click to cycle through each Tiles-per-row setting (3→8)."/>
                    <ToggleButton Name="DualViewButton"
                                  Classes="toolbar"
                                  Content="⧉ Dual"
                                  Click="ToggleDualView_Click"
                                  ToolTip.Tip="Show two instances of the module side by side to preview cross-instance sync"/>
                    <ToggleButton Name="SlidePreviewButton"
                                  Classes="toolbar"
                                  Content="↔ Slide"
                                  IsCheckedChanged="SlidePreviewButton_IsCheckedChanged"
                                  ToolTip.Tip="Loop the Docklys slide-in/out animation on the module preview"/>
                </StackPanel>

                <!-- Right: skin -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="Skin" Classes="caption"/>
                    <ComboBox Name="SkinComboBox"
                              MinWidth="120"
                              SelectionChanged="SkinComboBox_SelectionChanged"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═════════ Module preview: one or two slots + cycle arrows ═════════ -->
        <Grid Name="PreviewGrid" Grid.Row="1" ClipToBounds="False">
            <!-- Module slots: one visible by default, two when Dual is toggled. -->
            <StackPanel Name="ModulePreviewPanel"
                        Orientation="Horizontal"
                        Spacing="16"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <ContentControl Name="ActiveModuleSlot" />
                <ContentControl Name="SecondModuleSlot"
                                IsVisible="False" />
            </StackPanel>
            <Button Name="ScrollLeftButton"
                    Classes="scroll-arrow"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="10,0,0,0"
                    IsVisible="False"
                    Click="ScrollLeft_Click"
                    ToolTip.Tip="Previous module">
                <Path Data="M 12 0 L 0 16 L 12 32" />
            </Button>
            <Button Name="ScrollRightButton"
                    Classes="scroll-arrow"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,10,0"
                    IsVisible="False"
                    Click="ScrollRight_Click"
                    ToolTip.Tip="Next module">
                <Path Data="M 0 0 L 12 16 L 0 32" />
            </Button>

            <!-- ═════════ Theme Settings Overlay ═════════ -->
            <Border Name="ThemeSettingsOverlay"
                    IsVisible="False"
                    Background="#1A1A1A"
                    Width="280"
                    HorizontalAlignment="Left"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,0,1,0"
                    ZIndex="1000">
                <Grid RowDefinitions="Auto, *, Auto" Margin="16">
                    <StackPanel Grid.Row="0" Spacing="2" Margin="0,0,0,12">
                        <TextBlock Text="THEME SETTINGS"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Edit module color resources"
                                   FontSize="10"
                                   Opacity="0.5"
                                   Foreground="White"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" Margin="0,0,0,12">
                        <StackPanel Name="ThemeColorsContainer" Spacing="6">
                            <!-- Dynamic color entries will be added here from C# -->
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="Reset"
                                Classes="toolbar"
                                FontSize="10"
                                Click="ResetTheme_Click"/>
                        <Button Content="Close"
                                Classes="toolbar"
                                FontSize="10"
                                Click="CloseTheme_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═════════ Bottom bar: lifecycle | deploy | artifacts ═════════
             Three logical groups, separated by elastic gaps. Lifecycle on
             the left (Create/Reload), the headline deploy action centered
             and styled as primary, and artifact ops aligned right.        -->
        <Border Grid.Row="2"
                Classes="toolbar-bar"
                BorderThickness="0,1,0,0"
                Padding="10,6">
            <Grid ColumnDefinitions="Auto, *, Auto, *, Auto">

                <!-- Module lifecycle -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button Classes="toolbar"
                            Content="✚ New"
                            Click="CreateModule_Click"
                            ToolTip.Tip="Scaffold a new module by cloning DefaultModule"/>
                    <Button Classes="toolbar"
                            Content="↺ Reload"
                            Click="ReloadModule_Click"
                            ToolTip.Tip="Re-instantiate the active module"/>
                    <Button Name="ThemeButton"
                            Classes="toolbar"
                            Content="🎨 Theme"
                            Click="ThemeButton_Click"
                            ToolTip.Tip="Customize the global theme colors"/>
                </StackPanel>

                <!-- Deploy (center, primary styling) -->
                <Button Grid.Column="2"
                        Name="BuildDeployButton"
                        Classes="toolbar primary"
                        Content="⚡ Push to Docklys"
                        Click="BuildAndDeploy_Click"
                        ToolTip.ShowDelay="200"/>

                <!-- Artifacts -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button Classes="toolbar"
                            Content="⚖ Legal">
                        <Button.Flyout>
                            <MenuFlyout Placement="Top">
                                <MenuItem Header="Terms of Service" Click="OpenLegalLink_Click" Tag="https://docklys.qwqc.de/terms-of-service"/>
                                <MenuItem Header="Developer Terms" Click="OpenLegalLink_Click" Tag="https://docklys.qwqc.de/developer-terms"/>
                                <MenuItem Header="Privacy Policy" Click="OpenLegalLink_Click" Tag="https://docklys.qwqc.de/privacy-policy"/>
                                <MenuItem Header="Legal Notice" Click="OpenLegalLink_Click" Tag="https://docklys.qwqc.de/legal-notice"/>
                                <Separator/>
                                <MenuItem Header="Revocation Policy" Click="OpenLegalLink_Click" Tag="https://docklys.qwqc.de/revocation-policy"/>
                                <MenuItem Header="Credits &amp; Licenses" Click="OpenLegalLink_Click" Tag="https://docklys.qwqc.de/credits"/>
                                <MenuItem Header="Security Policy" Click="OpenLegalLink_Click" Tag="https://docklys.qwqc.de/security"/>
                                <MenuItem Header="Support &amp; FAQ" Click="OpenLegalLink_Click" Tag="https://docklys.qwqc.de/support"/>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <Button Classes="toolbar"
                            Content="Save .webp"
                            Click="CaptureToWebP_Click"
                            ToolTip.Tip="Save a screenshot of the active module"/>
                    <Button Classes="toolbar"
                            Content="Capture Dock"
                            Click="CaptureDock_Click"
                            ToolTip.Tip="Capture a screenshot of the main Docklys dock"/>
                    <Button Classes="toolbar"
                            Content="📂 .webp"
                            Click="OpenWebPFolder_Click"
                            ToolTip.Tip="Open the OutputWebPModule folder"/>
                    <Button Classes="toolbar"
                            Content="📂 .dll"
                            Click="OpenOutputModuleDllFolder_Click"
                            ToolTip.Tip="Open the OutputModuleDLL folder"/>
                    <Button Classes="toolbar"
                            Content="📂 Modules"
                            Click="OpenDocklyModulesFolder_Click"
                            ToolTip.Tip="Open the Dockly app's Modules folder"/>
                    <Button Classes="toolbar"
                            Content="📂 Saves"
                            Click="OpenSavesFolder_Click"
                            ToolTip.Tip="Open the module saves folder (%APPDATA%\Docklys\ModuleSaves)"/>
                    <Button Name="GitHubButton"
                            Classes="toolbar"
                            Content="GitHub"
                            Click="OnGitHubClick"
                            ToolTip.Tip="Create a GitHub repository for this module and push the source code"/>
                    <Button Classes="toolbar"
                            Content="Info"
                            Click="OnInfoClick"
                            ToolTip.Tip="Edit module description and sync from GitHub (saves to docklys.json)"/>
                    <Button Classes="toolbar"
                            Content="Images"
                            Click="OnImagesClick"
                            ToolTip.Tip="Manage module images: icon, preview screenshot, extra screenshots"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
