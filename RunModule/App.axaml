<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RunModule.App"
             xmlns:semi="https://irihi.tech/semi"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->
             <Application.Resources>
                 <!-- Global Monochrome Accent Palette (overrides default blue) -->
                 <Color x:Key="SystemAccentColor">#888888</Color>
                 <Color x:Key="SystemAccentColorLight1">#9A9A9A</Color>
                 <Color x:Key="SystemAccentColorLight2">#ABABAB</Color>
                 <Color x:Key="SystemAccentColorLight3">#BCBCBC</Color>
                 <Color x:Key="SystemAccentColorDark1">#777777</Color>
                 <Color x:Key="SystemAccentColorDark2">#666666</Color>
                 <Color x:Key="SystemAccentColorDark3">#555555</Color>

                 <SolidColorBrush x:Key="ColorBackground" Color="#2a3a3a"/>
                 <SolidColorBrush x:Key="ColorModuleBackground" Color="#2a3a3a"/>
                 <SolidColorBrush x:Key="ColorModuleBorder" Color="Transparent"/>
                 <SolidColorBrush x:Key="ColorBlack" Color="#2a3a3a"/>
                 <SolidColorBrush x:Key="ColorFont" Color="#4b5a52"/>
                 <SolidColorBrush x:Key="ColorModuleFont" Color="White"/>
                 <SolidColorBrush x:Key="ColorAccent" Color="#202723"/>
                 <SolidColorBrush x:Key="ColorGray" Color="#586960"/>
                 <Color x:Key="ColorModuleAccentColor">White</Color>
                 <SolidColorBrush x:Key="ColorModuleColor" Color="#363737"/>
             </Application.Resources>
    <Application.Styles>
        <FluentTheme />
        <semi:SemiTheme Locale="zh-CN" />
        <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />

        <!-- Scoped overrides for the Theme Settings and ColorPicker -->
        <Style Selector="Border#ThemeSettingsOverlay TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ColorModuleFont}" />
        </Style>
        <!-- Aggressively force all icons/paths in the theme sidebar to be monochrome -->
        <Style Selector="Border#ThemeSettingsOverlay Path">
            <Setter Property="Fill" Valufffffffffffffffffffffffffffffffffffffffffffffffffffe="{DynamicResource ColorModuleFont}" />
        </Style>
        <Style Selector="Border#ThemeSettingsOverlay PathIcon">
            <Setter Property="Foreground" Value="{DynamicResource ColorModuleFont}" />
        </Style>
        <Style Selector="ColorPicker /template/ Path">
            <Setter Property="Fill" Value="{DynamicResource ColorModuleFont}" />
        </Style>
        <Style Selector="ColorPicker /template/ TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ColorModuleFont}" />
        </Style>
        <Style Selector="ColorPicker /template/ DrawingPresenter">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="ColorPicker PathIcon">
            <Setter Property="Foreground" Value="{DynamicResource ColorModuleFont}" />
        </Style>
    </Application.Styles>
</Application>