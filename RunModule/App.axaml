<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RunModule.App"
             xmlns:semi="https://irihi.tech/semi"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->
             <Application.Resources>
                 <SolidColorBrush x:Key="ColorModuleFont" Color="White"/>
                 <Color x:Key="ColorModuleAccentColor">White</Color>
                 <SolidColorBrush x:Key="ColorModuleColor" Color="#363737"/>
             </Application.Resources>
    <Application.Styles>
        <FluentTheme />
        <semi:SemiTheme Locale="zh-CN" />
        <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />

        <!-- Scoped overrides for the Theme Settings and ColorPicker -->
        <Style Selector="Border#ThemeSettingsOverlay TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ColorModuleFont}" />
        </Style>
        <!-- Aggressively force all icons/paths in the theme sidebar to be monochrome -->
        <Style Selector="Border#ThemeSettingsOverlay Path">
            <Setter Property="Fill" Value="{DynamicResource ColorModuleFont}" />
        </Style>
        <Style Selector="Border#ThemeSettingsOverlay PathIcon">
            <Setter Property="Foreground" Value="{DynamicResource ColorModuleFont}" />
        </Style>
        <Style Selector="ColorPicker /template/ Path">
            <Setter Property="Fill" Value="{DynamicResource ColorModuleFont}" />
        </Style>
        <Style Selector="ColorPicker /template/ TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ColorModuleFont}" />
        </Style>
        <Style Selector="ColorPicker /template/ Image">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="ColorPicker PathIcon">
            <Setter Property="Foreground" Value="{DynamicResource ColorModuleFont}" />
        </Style>
    </Application.Styles>
</Application>