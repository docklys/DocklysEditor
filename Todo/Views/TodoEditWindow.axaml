<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Todo.Views.TodoEditWindow"
        Title="Edit Todo"
        Width="420" Height="380" WindowStartupLocation="CenterOwner">
    <Border Padding="12">
        <StackPanel Spacing="8">
            <TextBlock Text="Edit Todo" FontSize="16" FontWeight="Bold" />

            <TextBlock Text="Title" />
            <TextBox Text="{Binding Title, Mode=TwoWay}" />

            <TextBlock Text="Description" />
            <TextBox Text="{Binding Description, Mode=TwoWay}" AcceptsReturn="True" Height="120" />

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                <TextBlock Text="Category" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding Parent.Categories}" SelectedItem="{Binding Category, Mode=TwoWay}" Width="150" />

                <TextBlock Text="Priority" VerticalAlignment="Center" Margin="8,0,0,0" />
                <ComboBox SelectedItem="{Binding Priority, Mode=TwoWay}" Width="90">
                    <ComboBoxItem Content="high" />
                    <ComboBoxItem Content="medium" />
                    <ComboBoxItem Content="low" />
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
                <Button Content="Save" Command="{Binding SaveCommand}" />
                <Button Content="Cancel" Command="{Binding CancelCommand}" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
