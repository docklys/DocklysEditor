<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="spotify.spotify"
             x:Name="SpotifyRoot">

    <UserControl.Styles>
        <Style>
            <Style.Resources>
                <FontFamily x:Key="PressStart2P">avares://Docklys.ModuleContracts/Assets/Fonts/PressStart2P-Regular.ttf#Press Start 2P</FontFamily>
            </Style.Resources>
        </Style>

        <Style Selector="Button.resize-btn">
            <Setter Property="Background" Value="#363636"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource ColorModuleFont}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="11">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.resize-btn:pointerover">
            <Setter Property="Background" Value="#484848"/>
        </Style>
        <Style Selector="Button.resize-btn:pressed">
            <Setter Property="Background" Value="#242424"/>
        </Style>

        <Style Selector="Button.done-btn">
            <Setter Property="Background" Value="#363636"/>
            <Setter Property="Padding" Value="18,6"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource PressStart2P}"/>
            <Setter Property="FontSize" Value="7"/>
            <Setter Property="Foreground" Value="{DynamicResource ColorModuleFont}"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.done-btn:pointerover">
            <Setter Property="Background" Value="#484848"/>
        </Style>
        <Style Selector="Button.done-btn:pressed">
            <Setter Property="Background" Value="#242424"/>
        </Style>

    </UserControl.Styles>

    <Border Background="{DynamicResource ColorModuleColor}"
            Padding="0"
            Width="230"
            Height="350"
            CornerRadius="10"
            ClipToBounds="True">
        <Grid>
            <Grid x:Name="WebViewContainer"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch" />

            <!-- Accent pill in the bottom gap (below the WebView HWND edge) -->
            <Button x:Name="SettingsButton"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,1"
                    Width="34" Height="4"
                    MinWidth="0" MinHeight="0"
                    Background="{DynamicResource ColorAccent}"
                    Padding="0"
                    BorderThickness="0"
                    ZIndex="1000"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate>
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                MinWidth="0" MinHeight="0"/>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Settings overlay -->
            <Border x:Name="SettingsOverlay"
                    IsVisible="False"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="{DynamicResource ColorModuleColor}"
                    ZIndex="200">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="8">

                    <!-- Width row -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="5"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="W"
                                   FontFamily="{StaticResource PressStart2P}"
                                   FontSize="7"
                                   Foreground="{DynamicResource ColorModuleFont}"
                                   Opacity="0.45"
                                   VerticalAlignment="Center"
                                   Width="14"
                                   TextAlignment="Right"/>
                        <Button x:Name="WidthMinus" Content="−" Classes="resize-btn"/>
                        <TextBlock x:Name="WidthDisplay"
                                   Width="22"
                                   TextAlignment="Center"
                                   Foreground="{DynamicResource ColorModuleFont}"
                                   FontFamily="{StaticResource PressStart2P}"
                                   FontSize="8"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="WidthPlus" Content="+" Classes="resize-btn"/>
                    </StackPanel>

                    <!-- Height row -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="5"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="H"
                                   FontFamily="{StaticResource PressStart2P}"
                                   FontSize="7"
                                   Foreground="{DynamicResource ColorModuleFont}"
                                   Opacity="0.45"
                                   VerticalAlignment="Center"
                                   Width="14"
                                   TextAlignment="Right"/>
                        <Button x:Name="HeightMinus" Content="−" Classes="resize-btn"/>
                        <TextBlock x:Name="HeightDisplay"
                                   Width="22"
                                   TextAlignment="Center"
                                   Foreground="{DynamicResource ColorModuleFont}"
                                   FontFamily="{StaticResource PressStart2P}"
                                   FontSize="8"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="HeightPlus" Content="+" Classes="resize-btn"/>
                    </StackPanel>

                    <!-- DONE -->
                    <Button x:Name="CloseSettingsButton"
                            Classes="done-btn"
                            Content="DONE"
                            Margin="0,6,0,0"/>

                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
