<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="spotify.spotify"
             x:Name="SpotifyRoot">
    <Border Background="{DynamicResource ColorModuleColor}"
            Padding="0"
            Width="230"
            Height="230"
            CornerRadius="10"
            ClipToBounds="True">
        <Grid>
            <!-- WebView is created reflectively in OnAttachedToVisualTree to avoid
                 a hard compile-time dependency on WebView.Avalonia. If the host does
                 not have WebView loaded a fallback "Open in browser" button appears. -->
            <Grid x:Name="WebViewContainer"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch" />

            <!-- Settings Button (dot) in right-side gap (to avoid HWND overlap) -->
            <Button x:Name="SettingsButton"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,20"
                    Width="5" Height="5"
                    CornerRadius="2.5"
                    Background="{DynamicResource ColorModuleAccentColor}"
                    Padding="0"
                    BorderThickness="0"
                    ZIndex="1000" />

            <!-- Full-cover settings overlay -->
            <Border x:Name="SettingsOverlay"
                    IsVisible="False"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="{DynamicResource ColorModuleColor}"
                    Opacity="0.95"
                    ZIndex="200">
                <Viewbox Stretch="Uniform" Margin="8">
                    <StackPanel Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="SETTINGS"
                                   Foreground="{DynamicResource ColorModuleFont}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   LetterSpacing="2"
                                   Opacity="0.6"
                                   HorizontalAlignment="Center" />

                        <Border Background="{DynamicResource ColorModuleAccentColor}" 
                                CornerRadius="6" 
                                Padding="12,8"
                                BorderBrush="{DynamicResource ColorModuleFont}"
                                BorderThickness="1">
                            <StackPanel Spacing="10">
                                <!-- Width row -->
                                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                                    <Button x:Name="WidthMinus"
                                            Content="−"
                                            Width="24" Height="24"
                                            FontSize="16"
                                            Padding="0"
                                            Background="Transparent"
                                            Foreground="{DynamicResource ColorModuleFont}"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center" />
                                    <TextBlock x:Name="WidthDisplay"
                                               Width="24"
                                               TextAlignment="Center"
                                               Foreground="{DynamicResource ColorModuleFont}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center" />
                                    <Button x:Name="WidthPlus"
                                            Content="+"
                                            Width="24" Height="24"
                                            FontSize="16"
                                            Padding="0"
                                            Background="Transparent"
                                            Foreground="{DynamicResource ColorModuleFont}"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center" />
                                </StackPanel>

                                <!-- Height row -->
                                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                                    <Button x:Name="HeightMinus"
                                            Content="−"
                                            Width="24" Height="24"
                                            FontSize="16"
                                            Padding="0"
                                            Background="Transparent"
                                            Foreground="{DynamicResource ColorModuleFont}"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center" />
                                    <TextBlock x:Name="HeightDisplay"
                                               Width="24"
                                               TextAlignment="Center"
                                               Foreground="{DynamicResource ColorModuleFont}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center" />
                                    <Button x:Name="HeightPlus"
                                            Content="+"
                                            Width="24" Height="24"
                                            FontSize="16"
                                            Padding="0"
                                            Background="Transparent"
                                            Foreground="{DynamicResource ColorModuleFont}"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Button x:Name="CloseSettingsButton"
                                Content="DONE"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource ColorModuleAccentColor}"
                                Foreground="{DynamicResource ColorModuleFont}"
                                Padding="24,6"
                                FontSize="11"
                                CornerRadius="4"
                                FontWeight="Bold"/>
                    </StackPanel>
                </Viewbox>
            </Border>
        </Grid>
    </Border>
</UserControl>
